@model WorkingDaysVM
@{
    ViewData["Title"] = "Working Days Calculator";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded shadow-sm p-4">
        <h1 class="text-center">Working Days Calculator</h1>
        <hr />
        <form asp-action="Calculate" method="post">
            <div class="row g-3">
                <div class="col-md-6 text-center">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6 text-center">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary px-5 btn-lg">Calculate</button>
            </div>
        </form>
    </div>
</div>

@if (Model.WorkingDays.HasValue)
{
    <div class="row justify-content-center mt-4">
        <div class="col-md-6 text-center bg-light border p-4 rounded">

            @if (Model.StartDate.Value.DayOfWeek == DayOfWeek.Saturday
                                                || Model.StartDate.Value.DayOfWeek == DayOfWeek.Sunday)
            {
                <p class="text-danger small">
                    Start date falls on a weekend!
                </p>
                <hr />
            }
            else
            {
                <h1>@Model.WorkingDays Working Days</h1>
                <p class="text-muted">
                    Between @Model.StartDate.Value.ToString("dd MMM yyyy")
                    and @Model.EndDate.Value.ToString("dd MMM yyyy")
                </p>
                <hr />
            }

            @if (Model.PublicHolidaysBetweenDates.Any())
            {
                <table class="table table-sm table-bordered mt-4 text-start">
                    <thead><tr><th>Holiday Date</th><th>Holiday Name</th></tr></thead>
                    <tbody>
                        @foreach (var h in Model.PublicHolidaysBetweenDates)
                        {
                            <tr><td>@h.Date.ToShortDateString()</td><td>@h.Name</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function()
        {
            const selectDate = $("#StartDate").val()
            const date = new Date(selectDate)
            const day = date.getUTCDay();

            if (day == 0 || day == 6) {
                    $('[data-valmsg-for="StartDate"]').text("you have to choose a week day as a starting date");
            }
        })
    </script>
}
