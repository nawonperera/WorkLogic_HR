@model WorkLogic_HR.Core.DTO.EmployeeDto
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded shadow-sm p-4 text-center">
        <h1>Edit Employee</h1>
        <hr />
        <form asp-action="Update" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label font-weight-bold text-start"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label font-weight-bold text-start"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="JobPosition" class="form-label font-weight-bold text-start"></label>
                <input asp-for="JobPosition" class="form-control" />
                <span asp-validation-for="JobPosition" class="text-danger small"></span>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <button type="submit" class="btn btn-warning px-5 text-dark">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
