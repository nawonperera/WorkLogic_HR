@model IEnumerable<WorkLogic_HR.Core.DTO.PublicHolidayDto>
@{
    ViewData["Title"] = "Public Holidays";
}

<div class="row align-items-center mb-3">
    <div class="col">
        <h1>Public Holidays</h1>
    </div>
    <div class="col text-end">
        <a asp-action="Create" class="btn btn-danger">Add Holiday</a>
    </div>
</div>



@if (!Model.Any())
{
    <div class="alert alert-info">No holidays found.</div>
}
else
{
    <table class="table table-bordered table-striped" id="holidayTable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Day</th>
                <th>Name</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var holiday in Model)
            {
                <tr class="holiday-row" data-year="@holiday.Date.Year">
                    <td>@holiday.Id</td>
                    <td>@holiday.Date.ToString("dd MMM yyyy")</td>
                    <td>@holiday.Date.DayOfWeek</td>
                    <td class="fw-semibold">@holiday.Name</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@holiday.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger deleteBtn">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        
        $(document).ready(function () {
            $(".deleteBtn").click(function () {
                return confirm("Delete holiday?");
            });
        });
    </script>
}
