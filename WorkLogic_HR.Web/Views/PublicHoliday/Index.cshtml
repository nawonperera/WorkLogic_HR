@model IEnumerable<WorkLogic_HR.Core.DTO.PublicHolidayDto>
@{
    ViewData["Title"] = "Public Holidays";
}

<div class="row align-items-center mb-3">
    <div class="col">
        <h1>Public Holidays</h1>
    </div>
    <div class="col text-end">
        <a asp-action="Create" class="btn btn-danger">Add Holiday</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body bg-light">
        <div class="row">
            <div class="col-auto">
                <label class="form-label mb-0 pt-2">Filter by Year:</label>
            </div>
            <div class="col-auto">
                <select id="yearFilter" class="form-select">
                    <option value="all">All Years</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No holidays found.</div>
}
else
{
    <table class="table table-bordered table-striped" id="holidayTable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Day</th>
                <th>Name</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var holiday in Model)
            {
                <tr class="holiday-row" data-year="@holiday.Date.Year">
                    <td>@holiday.Id</td>
                    <td>@holiday.Date.ToString("dd MMM yyyy")</td>
                    <td>@holiday.Date.DayOfWeek</td>
                    <td class="fw-semibold">@holiday.Name</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@holiday.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" id="deleteBtn">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            var years = [];
            $('#holidayTable .holiday-row').each(function () {
                var year = $(this).data('year');
                if ($.inArray(year, years) === -1) {
                    years.push(year);
                    $('#yearFilter').append('<option value="' + year + '">' + year + '</option>');
                }
            });

            $('#yearFilter').on('change', function () {
                var year = $(this).val();
                if (year === 'all') {
                    $('#holidayTable .holiday-row').show();
                } else {
                    $('#holidayTable .holiday-row').hide().filter('[data-year="' + year + '"]').show();
                }
            });
        });
        $(document).ready(function () {
            $("#deleteBtn").click(function () {
                return confirm("Delete holiday?");
            });
        });
    </script>
}
